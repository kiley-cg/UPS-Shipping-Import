# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# In production these are stored as GitHub Actions secrets, not in this file.

# ── Syncore ────────────────────────────────────────────────
# Your Syncore API key (Settings → API in Syncore)
SYNCORE_API_KEY=your_syncore_api_key_here

# ── Email (Gmail with App Password) ────────────────────────
# The Gmail address the script sends FROM
GMAIL_USER=kiley@colorgraphicswa.com

# Gmail App Password (not your regular password).
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on the account.
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# CSR group email — errors and suboutcorex notices go here
CSR_EMAIL=csr@colorgraphicswa.com

# ── Google Drive API ───────────────────────────────────────
# The full JSON content of your Google Service Account key file.
# In GitHub Actions this is stored as a secret.
# For local testing: paste the entire JSON on one line, or use a multiline value.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# The ID of the "UPS Shipping Info" shared drive folder.
# Find it in the URL when you open the folder in Google Drive:
#   https://drive.google.com/drive/folders/THIS_PART_IS_THE_ID
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# ── Local fallback (optional) ──────────────────────────────
# Only used when GOOGLE_SERVICE_ACCOUNT_JSON is NOT set.
# Useful for testing on a Mac that has Google Drive synced locally.
# UPS_DRIVE_PATH=/Users/kileygustafson/Library/CloudStorage/GoogleDrive-kiley@colorgraphicswa.com/Shared drives/UPS Shipping Info
